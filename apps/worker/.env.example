# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://bulksend:changeme@localhost:5432/bulksend"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://:changeme@localhost:6379"

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS="localhost:9092"

# ─── SendGrid ────────────────────────────────────────────────────────────────
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Worker ──────────────────────────────────────────────────────────────────
NODE_ENV=development
# Optional suffix appended to consumer group IDs (useful for running multiple
# worker instances locally without consumer group conflicts)
KAFKA_GROUP_ID_SUFFIX=""
