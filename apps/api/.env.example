# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://bulksend:changeme@localhost:5432/bulksend"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://:changeme@localhost:6379"

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS="localhost:9092"

# ─── JWT (generate with: openssl rand -hex 32) ───────────────────────────────
JWT_SECRET="change-me-generate-with-openssl-rand-hex-32-aaaaaaaaaaaaaaaa"
JWT_REFRESH_SECRET="change-me-generate-with-openssl-rand-hex-32-bbbbbbbbbbbbbbbb"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── SendGrid ────────────────────────────────────────────────────────────────
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Webhook & tracking (generate with: openssl rand -hex 16) ────────────────
SENDGRID_WEBHOOK_SECRET="dev-webhook-secret"
TRACKING_SECRET="dev-tracking-secret"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
